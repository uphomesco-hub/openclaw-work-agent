{
  "version": 1,
  "activeCompany": "example-startup",
  "permissionMode": "ask",
  "notifyTarget": "telegram:123456789",
  "quietScheduledRuns": true,
  "learningLoop": {
    "enabled": true,
    "captureEveryWorkTask": true,
    "writePlaybooks": true,
    "lookForFasterPath": true
  },
  "companies": {
    "example-startup": {
      "name": "Example Startup",
      "slug": "example-startup",
      "businessSummary": "Example Startup helps a specific customer segment solve a specific operating problem.",
      "customerSegments": [
        "Primary buyer",
        "Daily operator",
        "End user"
      ],
      "productSurfaces": [
        "web app",
        "website",
        "admin panel",
        "backend",
        "support inbox"
      ],
      "keyWorkflows": [
        "signup",
        "lead creation",
        "payment",
        "support",
        "deployment"
      ],
      "goals": [
        "Increase qualified signups",
        "Reduce support response time",
        "Find product bugs before users churn"
      ],
      "firebaseProject": "example-project-id",
      "gmailAccount": "founder@example.com",
      "websiteUrl": "https://example.com",
      "localRepos": [
        "$HOME/path/to/company-app",
        "$HOME/path/to/company-website"
      ],
      "githubRepos": [
        "your-org/company-app",
        "your-org/company-website"
      ],
      "driveFolders": [
        "https://drive.google.com/drive/folders/example-folder-id"
      ],
      "obsidianCompanyDir": "$HOME/Documents/Obsidian-Work-Brain/wiki/projects/example-startup-work-agent",
      "metricsToWatch": [
        "new users per day",
        "support emails from last 24h",
        "database error signals",
        "conversion blockers",
        "repeat customer complaints"
      ],
      "growthChannels": [
        "SEO content",
        "direct sales",
        "referrals"
      ],
      "risks": [
        "production data mistakes",
        "customer-impacting downtime",
        "bad external replies"
      ],
      "decisionRules": [
        "urgent customer-impacting issues come before growth suggestions",
        "ask before production writes or external sends"
      ],
      "connectorsWanted": [
        "database",
        "backend logs",
        "mail",
        "slack",
        "github",
        "analytics",
        "payments",
        "ads",
        "docs",
        "support tool",
        "internal APIs"
      ],
      "thresholds": {
        "gmailImportant": {
          "enabled": true,
          "lookback": "1d",
          "maxResults": 10,
          "notifyOnCount": 1,
          "queryTerms": [
            "feedback",
            "urgent",
            "issue",
            "problem",
            "bug",
            "refund",
            "payment",
            "not working",
            "error",
            "complaint",
            "support"
          ]
        },
        "gmailUrgent": {
          "enabled": true,
          "lookback": "1d",
          "maxResults": 10,
          "notifyOnCount": 1,
          "queryTerms": [
            "urgent",
            "emergency",
            "not working",
            "payment failed",
            "refund",
            "complaint",
            "security",
            "crash",
            "down",
            "error"
          ],
          "ignoreTerms": [
            "receipt",
            "invoice paid",
            "payment received"
          ]
        },
        "firebaseOps": {
          "enabled": true,
          "notifyOnFunctionErrors": true,
          "notifyOnNoOnlineUsers": false,
          "newPropertyLookbackHours": 24
        },
        "reporting": {
          "lightMonitorWritesReport": true,
          "deepReportWritesSummary": true,
          "notifyOnlyWhenActionRequired": true
        }
      },
      "approvalPolicy": {
        "defaultMode": "ask",
        "alwaysConfirm": [
          "email_send",
          "external_message_send",
          "database_delete",
          "database_replace_subtree",
          "deploy",
          "project_or_app_create",
          "payment_change",
          "ad_spend_change"
        ]
      }
    }
  }
}
