{
  "version": 1,
  "activeCompany": "uphomes",
  "permissionMode": "ask",
  "notifyTarget": "telegram:YOUR_TELEGRAM_CHAT_ID",
  "quietScheduledRuns": true,
  "companies": {
    "uphomes": {
      "name": "UpHomes",
      "slug": "uphomes",
      "businessSummary": "UpHomes is a rental marketplace for tenants, property owners, flatmates, and microbrokers.",
      "customerSegments": [
        "tenants",
        "property owners",
        "flatmates",
        "microbrokers"
      ],
      "productSurfaces": [
        "mobile app",
        "website",
        "Firebase backend",
        "support inbox",
        "SEO blog"
      ],
      "keyWorkflows": [
        "tenant signup",
        "property publishing",
        "contact or call activity",
        "lead conversion",
        "support and feedback",
        "content publishing"
      ],
      "goals": [
        "Improve rental lead conversion",
        "Catch app/backend issues quickly",
        "Understand user and property activity from Firebase",
        "Turn repeated support and ops work into OpenClaw skills"
      ],
      "firebaseProject": "your-firebase-project-id",
      "gmailAccount": "founder@example.com",
      "websiteUrl": "https://your-uphomes-site.example",
      "localRepos": [
        "$HOME/path/to/uphomes-app",
        "$HOME/path/to/uphomes-website"
      ],
      "githubRepos": [
        "your-org/uphomes-app",
        "your-org/uphomes-website"
      ],
      "driveFolders": [],
      "obsidianCompanyDir": "$HOME/Documents/Obsidian-Work-Brain/wiki/projects/uphomes-work-agent",
      "metricsToWatch": [
        "new users",
        "new or updated properties",
        "online users from RTDB presence",
        "Cloud Functions errors",
        "support and feedback emails",
        "manual ops tasks that repeat"
      ],
      "growthChannels": [
        "SEO blogs",
        "rental locality pages",
        "referrals",
        "Meta Ads after connector setup"
      ],
      "risks": [
        "wrong production database changes",
        "bad customer replies",
        "Cloud Functions failures",
        "ad spend waste",
        "payment or subscription issues"
      ],
      "decisionRules": [
        "live app/backend issues are urgent",
        "support and payment issues should be surfaced quickly",
        "ask before production writes, deploys, external messages, or spend changes"
      ],
      "connectorsWanted": [
        "firebase",
        "gmail",
        "drive",
        "obsidian",
        "telegram",
        "meta-ads"
      ],
      "thresholds": {
        "gmailImportant": {
          "enabled": true,
          "lookback": "1d",
          "maxResults": 10,
          "notifyOnCount": 1,
          "queryTerms": [
            "feedback",
            "urgent",
            "issue",
            "problem",
            "bug",
            "refund",
            "payment",
            "not working",
            "error",
            "complaint",
            "support",
            "lead",
            "property",
            "broker",
            "brokerage"
          ]
        },
        "firebaseOps": {
          "enabled": true,
          "notifyOnFunctionErrors": true,
          "notifyOnNoOnlineUsers": false,
          "newPropertyLookbackHours": 24
        },
        "reporting": {
          "lightMonitorWritesReport": true,
          "deepReportWritesSummary": true,
          "notifyOnlyWhenActionRequired": true
        }
      },
      "approvalPolicy": {
        "defaultMode": "ask",
        "alwaysConfirm": [
          "email_send",
          "external_message_send",
          "database_delete",
          "database_replace_subtree",
          "deploy",
          "project_or_app_create",
          "payment_change",
          "ad_spend_change"
        ]
      }
    }
  }
}
