function extractJsonObject(text) {
  const start = text.indexOf("{");
  const end = text.lastIndexOf("}");
  if (start === -1 || end === -1 || end <= start) return null;
  return readJsonFromString(text.slice(start, end + 1));
}

function readJsonFromString(text) {
  try {
    return JSON.parse(text);
  } catch {
    return null;
  }
}

function readOpenClawMcp() {
  if (!commandExists("openclaw")) return { ok: false, servers: {}, reason: "openclaw command not found" };
  const result = run("openclaw", ["mcp", "show"], { timeout: 30000 });
  if (!result.ok) return { ok: false, servers: {}, reason: result.stderr || result.stdout || "openclaw mcp show failed" };
  const parsed = extractJsonObject(result.stdout);
  return { ok: true, servers: parsed || {}, raw: result.stdout };
}

function readOpenClawConfigSummary() {
  const file = expand("~/.openclaw/openclaw.json");
  const config = readJson(file, {});
  const telegram = config?.channels?.telegram || {};
  const memoryWiki = config?.plugins?.entries?.["memory-wiki"] || {};
  return {
    path: file,
    telegramEnabled: Boolean(telegram.enabled),
    telegramAllowFromCount: Array.isArray(telegram.allowFrom) ? telegram.allowFrom.length : 0,
    memoryWikiEnabled: Boolean(memoryWiki.enabled),
    memoryWikiVault: memoryWiki?.config?.vault?.path || ""
  };
}

function readGogAccounts() {
  if (!commandExists("gog")) return { ok: false, accounts: [], reason: "gog command not found" };
  const result = run("gog", ["auth", "list"], { timeout: 30000 });
  if (!result.ok) return { ok: false, accounts: [], reason: result.stderr || result.stdout || "gog auth list failed" };
  const accounts = result.stdout
    .split(/\r?\n/)
    .map((line) => line.trim())
    .filter(Boolean)
    .map((line) => {
      const parts = line.split(/\s+/);
      return {
        email: parts[0] || "",
        label: parts[1] || "",
        services: parts[2] ? parts[2].split(",") : []
      };
    })
    .filter((account) => account.email.includes("@"));
  return { ok: true, accounts };
}

function readMcporterServers() {
  if (!commandExists("mcporter")) return { ok: false, servers: [], reason: "mcporter command not found" };
  const result = run("mcporter", ["list"], { timeout: 30000 });
  if (!result.ok) return { ok: false, servers: [], reason: result.stderr || result.stdout || "mcporter list failed" };
  if (/No MCP servers configured/i.test(result.stdout)) return { ok: true, servers: [], reason: "No MCP servers configured" };
  const servers = result.stdout
    .split(/\r?\n/)
    .map((line) => line.trim())
    .filter(Boolean)
    .map((line) => line.split(/\s+/)[0]);
  return { ok: true, servers };
}

function discoverConnectors(config) {
  const openclawConfig = readOpenClawConfigSummary();
  const mcp = readOpenClawMcp();
  const gog = readGogAccounts();
  const mcporter = readMcporterServers();
  const obsidianBridge = path.join(DEFAULT_TOOLS_DIR, "openclaw-obsidian");
  const obsidianOk = fs.existsSync(obsidianBridge) || commandExists("openclaw-obsidian");
  const mcpServerNames = Object.keys(mcp.servers || {});
  const mcporterNames = mcporter.servers || [];
  const allServerNames = [...new Set([...mcpServerNames, ...mcporterNames])];
  const hasMetaAds = allServerNames.some((name) => /meta|facebook|ads/i.test(name));
  const { company } = activeCompany(config);

  return {
    generatedAt: nowIso(),
    openclaw: {
      installed: commandExists("openclaw"),
      mcpOk: mcp.ok,
      mcpServers: mcpServerNames,
      telegramEnabled: openclawConfig.telegramEnabled,
      memoryWikiEnabled: openclawConfig.memoryWikiEnabled,
      memoryWikiVault: openclawConfig.memoryWikiVault
    },
    firebase: {
      connected: mcpServerNames.includes("firebase") || mcporterNames.includes("firebase"),
      project: company.firebaseProject || "",
      via: mcpServerNames.includes("firebase") ? "openclaw-mcp" : mcporterNames.includes("firebase") ? "mcporter" : ""
    },
    googleWorkspace: {
      connected: gog.ok && gog.accounts.length > 0,
      accounts: gog.accounts,
      selectedGmailAccount: company.gmailAccount || ""
    },
    obsidian: {
      connected: obsidianOk || openclawConfig.memoryWikiEnabled,
      bridgePath: fs.existsSync(obsidianBridge) ? obsidianBridge : "",
      companyDir: expand(company.obsidianCompanyDir || "")
    },
    telegram: {
      connected: openclawConfig.telegramEnabled,
      notifyTargetConfigured: Boolean(config.notifyTarget)
    },
    metaAds: {
      connected: hasMetaAds,
      status: hasMetaAds ? "connected" : "connector_needed",
      setup: hasMetaAds ? "" : "Install or configure a Meta Ads MCP/API connector, then add it to OpenClaw MCP config."
    },
    mcporter: {
      configured: mcporter.ok && mcporterNames.length > 0,
      servers: mcporterNames,
      note: mcporter.ok ? mcporter.reason || "" : mcporter.reason
    }
  };
}

function connectorRows(discovery) {
  return [
    ["Firebase", discovery.firebase.connected, discovery.firebase.via || "missing", discovery.firebase.project || "-"],
    ["Google Workspace", discovery.googleWorkspace.connected, "gog", discovery.googleWorkspace.selectedGmailAccount || discovery.googleWorkspace.accounts.map((a) => a.email).join(", ") || "-"],
    ["Obsidian", discovery.obsidian.connected, discovery.obsidian.bridgePath ? "openclaw-obsidian" : "memory-wiki", discovery.obsidian.companyDir || "-"],
    ["Telegram", discovery.telegram.connected, "openclaw channel", discovery.telegram.notifyTargetConfigured ? "target configured" : "target missing"],
    ["Meta Ads", discovery.metaAds.connected, discovery.metaAds.status, discovery.metaAds.setup || "-"],
    ["mcporter", discovery.mcporter.configured, "optional direct MCP", discovery.mcporter.servers.join(", ") || discovery.mcporter.note || "-"]
  ];
}

function boolValue(value, fallback = false) {
  return typeof value === "boolean" ? value : fallback;
}

function numberValue(value, fallback) {
  return typeof value === "number" && Number.isFinite(value) ? value : fallback;
}

function stringArray(value) {
  return Array.isArray(value) ? value.map(String).filter(Boolean) : [];
}

function buildGmailQuery(settings) {
  const lookback = settings.lookback || "1d";
  const terms = stringArray(settings.queryTerms);
  const inner = terms.length ? terms.map((term) => `"${term.replace(/"/g, "")}"`).join(" OR ") : "\"feedback\" OR \"urgent\"";
  return `newer_than:${lookback} (${inner})`;
}

function parseGmailTable(stdout) {
  return stdout
    .split(/\r?\n/)
    .map((line) => line.trim())
    .filter((line) => line && !line.startsWith("ID "))
    .map((line) => {
      const parts = line.split(/\s{2,}/);
      return {
        id: parts[0] || "",
        thread: parts[1] || "",
        date: parts[2] || "",
        from: parts[3] || "",
        subject: parts[4] || "",
        labels: parts.slice(5).join(" ")
      };
    })
    .filter((item) => item.id && item.subject);
}

function filterImportantMail(messages, settings) {
  const terms = stringArray(settings.queryTerms).map((term) => term.toLowerCase());
  if (!terms.length) return messages;
  return messages.filter((message) => {
    const haystack = `${message.from} ${message.subject} ${message.labels}`.toLowerCase();
    return terms.some((term) => haystack.includes(term));
  });
}

function runGmailImportantCheck(company, discovery) {
  const settings = company.thresholds?.gmailImportant || {};
  if (!boolValue(settings.enabled, false)) {
    return { name: "Gmail important mail", enabled: false, ok: true, actionRequired: false, summary: "disabled", items: [] };
  }
  if (!discovery.googleWorkspace.connected) {
    return { name: "Gmail important mail", enabled: true, ok: false, actionRequired: true, summary: "Google Workspace is not connected", items: [] };
  }

  const account = company.gmailAccount || discovery.googleWorkspace.accounts?.[0]?.email || "";
  if (!account) {
    return { name: "Gmail important mail", enabled: true, ok: false, actionRequired: true, summary: "No Gmail account configured", items: [] };
  }

  const query = buildGmailQuery(settings);
  const maxResults = String(numberValue(settings.maxResults, 10));
  const result = run("gog", ["gmail", "messages", "search", query, "--max", maxResults, "--account", account], { timeout: 60000 });
  if (!result.ok) {
    return {
      name: "Gmail important mail",
      enabled: true,
      ok: false,
      actionRequired: true,
      summary: result.stderr || result.stdout || "Gmail search failed",
      items: []
    };
  }

  const messages = filterImportantMail(parseGmailTable(result.stdout), settings);
  const notifyOnCount = numberValue(settings.notifyOnCount, 1);
  return {
    name: "Gmail important mail",
    enabled: true,
    ok: true,
    actionRequired: messages.length >= notifyOnCount,
    summary: `${messages.length} important message(s) matched threshold query`,
    query,
    items: messages.slice(0, 5)
  };
}

function runThresholdChecks(config, discovery, options = {}) {
  const { company } = activeCompany(config);
  const checks = [
    runGmailImportantCheck(company, discovery)
  ];
  const actionRequired = checks.some((check) => check.enabled !== false && check.actionRequired);
  return {
    mode: options.scheduled ? "scheduled" : "manual",
    actionRequired,
    checks
  };
}

function printStatus(discovery, asJson = false) {
  if (asJson) {
    console.log(JSON.stringify(discovery, null, 2));
    return;
  }
  console.log("OpenClaw Ops Brain status");
  console.log(`Generated: ${discovery.generatedAt}`);
  console.log("");
  for (const [name, ok, via, detail] of connectorRows(discovery)) {
    console.log(`${ok ? "OK " : "MISS"} ${name}: ${via}${detail ? ` (${detail})` : ""}`);
  }
}

function buildReport(config, discovery, options = {}) {
  const { key, company } = activeCompany(config);
  const rows = connectorRows(discovery);
  const thresholdResult = options.thresholdResult || runThresholdChecks(config, discovery, options);
  const sourceContext = collectSourceContext(company);
  const missing = rows.filter(([, ok]) => !ok).map(([name, , via, detail]) => ({ name, via, detail }));
  const goals = company.goals?.length ? company.goals : ["No goals configured yet"];
  const metrics = company.metricsToWatch?.length ? company.metricsToWatch : ["No metrics configured yet"];
  const customerSegments = company.customerSegments?.length ? company.customerSegments : ["No customer segments configured yet"];
  const productSurfaces = company.productSurfaces?.length ? company.productSurfaces : ["No product surfaces configured yet"];
  const keyWorkflows = company.keyWorkflows?.length ? company.keyWorkflows : ["No critical workflows configured yet"];
  const growthChannels = company.growthChannels?.length ? company.growthChannels : ["No growth channels configured yet"];
  const risks = company.risks?.length ? company.risks : ["No explicit risks configured yet"];
  const decisionRules = company.decisionRules?.length ? company.decisionRules : ["No decision rules configured yet"];
  const mode = config.permissionMode === "full" ? "full-access" : "ask-then-execute";

  const actionCandidates = [];
  if (!discovery.metaAds.connected) {
    actionCandidates.push("Connect a Meta Ads MCP/API source before asking for ad strategy or spend optimization.");
  }
  if (!discovery.googleWorkspace.connected) {
    actionCandidates.push("Run Google Workspace auth setup with `gog auth add ...` for Gmail/Drive checks.");
  }
  if (!discovery.firebase.connected) {
    actionCandidates.push("Connect Firebase MCP through OpenClaw before live app/database checks.");
  }
  if (!company.goals?.length) {
    actionCandidates.push("Add 3-5 business goals so the agent can judge whether anomalies matter.");
  }

  const lines = [
    "---",
    `title: ${company.name} Ops Brain Report`,
    `generated: ${discovery.generatedAt}`,
    `company: ${company.name}`,
    `permission_mode: ${mode}`,
    `scheduled: ${Boolean(options.scheduled)}`,
    `dry_run: ${Boolean(options.dryRun)}`,
    "---",
    "",
    `# ${company.name} Ops Brain Report`,
    "",
    "## Summary",
    "",
    `- Active profile: ${key}`,
    `- Business: ${company.businessSummary || "not configured"}`,
    `- Permission mode: ${mode}`,
    `- Firebase project: ${company.firebaseProject || "not configured"}`,
    `- Notification target: ${config.notifyTarget || "not configured"}`,
    `- Website: ${company.websiteUrl || "not configured"}`,
    "",
    "## Connector Inventory",
    "",
    "| Source | Status | Route | Detail |",
    "| --- | --- | --- | --- |",
    ...rows.map(([name, ok, via, detail]) => `| ${name} | ${ok ? "connected" : "missing"} | ${via || "-"} | ${sanitizeTable(detail || "-")} |`),
    "",
    "## Business Goals",
    "",
    ...goals.map((goal) => `- ${goal}`),
    "",
    "## Company Operating Map",
    "",
    "### Customers",
    "",
    ...customerSegments.map((item) => `- ${item}`),
    "",
    "### Product Surfaces",
    "",
    ...productSurfaces.map((item) => `- ${item}`),
    "",
    "### Critical Workflows",
    "",
    ...keyWorkflows.map((item) => `- ${item}`),
    "",
    "### Growth Channels",
    "",
    ...growthChannels.map((item) => `- ${item}`),
    "",
    "### Risks And Care Points",
    "",
    ...risks.map((item) => `- ${item}`),
    "",
    "### Decision Rules",
    "",
    ...decisionRules.map((item) => `- ${item}`),
    "",
    "## Metrics To Watch",
    "",
    ...metrics.map((metric) => `- ${metric}`),
    "",
    "## Connection Plan",
    "",
    ...formatConnectionPlan(discovery, company),
    "",
    "## Website And Code Context",
    "",
    ...formatSourceContextReport(sourceContext),
    "",
    "## Live Business Snapshot For OpenClaw Brain",
    "",
    "- Build a live picture across every connected source before answering strategic work questions.",
    "- Use Firebase MCP to check RTDB online users, users created today, user activity signals, properties/listings published or updated today, and Cloud Functions errors.",
    "- Use Gmail to inspect important feedback, lead, complaint, payment, and support candidates before suggesting action.",
    "- Use Drive/docs and Obsidian to understand operating context, company decisions, specs, and repeated workflows.",
    "- Use repo and website context to suggest product, performance, SEO, blog, and conversion improvements.",
    "- Save important conclusions back into this work vault so the company brain compounds.",
    "",
    "## Threshold Checks",
    "",
    `- Action required: ${thresholdResult.actionRequired ? "yes" : "no"}`,
    ...thresholdResult.checks.map((check) => `- ${check.name}: ${check.enabled === false ? "disabled" : check.ok ? "ok" : "error"} - ${check.summary}`),
    "",
    "## Important Mail Matches",
    "",
    ...formatMailMatches(thresholdResult),
    "",
    "## V1 UpHomes Ops Checks",
    "",
    "- Firebase: use OpenClaw MCP for users, properties/listings, RTDB presence, Functions logs, Remote Config, and Storage metadata.",
    "- Gmail: use `gog` for support, feedback, billing, and partnership emails.",
    "- Drive: use `gog` for selected docs/folders and operating notes.",
    "- Obsidian: use the company wiki folder as the durable operating memory.",
    "- Meta Ads: report as missing until a real connector is added.",
    "",
    "## Action Candidates",
    "",
    ...(actionCandidates.length ? actionCandidates.map((item) => `- ${item}`) : ["- No connector blockers found. Next scheduled runs should focus on live business anomalies."]),
    "",
    "## Permission Boundary",
    "",
    "- Default behavior is ask-then-execute.",
    "- Full-access mode can be enabled, but emails/messages, deletes, deploys, app/project creation, payment/ad-spend changes, and replace-subtree database writes still require exact confirmation.",
    "",
    "## Suggested Skill Candidates",
    "",
    "- Customer feedback triage skill for recurring Gmail/app complaints.",
    "- Firebase anomaly review skill for properties, users, online presence, and function errors.",
    "- Meta Ads strategy skill after a connector is installed.",
    "- Weekly founder digest skill that converts reports into decisions and next actions.",
    ""
  ];

  return {
    markdown: lines.join("\n"),
    summary: {
      company: company.name,
      permissionMode: mode,
      missingConnectors: missing.map((m) => m.name),
      actionCandidates,
      sourceContext,
      actionRequired: thresholdResult.actionRequired,
      thresholdChecks: thresholdResult.checks.map((check) => ({
        name: check.name,
        ok: check.ok,
        actionRequired: check.actionRequired,
        summary: check.summary
      })),
      reportType: options.scheduled ? "scheduled" : "manual"
    }
  };
}

function formatSourceContextReport(sourceContext) {
  const lines = [];
  if (!sourceContext.repos.length) {
    lines.push("- No local code repositories configured.");
  } else {
    for (const repo of sourceContext.repos) {
      lines.push(`- ${repo.name}: ${repo.ok ? repo.latestCommit || "no commit found" : "not a git repo or unavailable"}`);
      if (repo.branch) lines.push(`  - Branch: ${repo.branch}`);
      if (repo.remote) lines.push(`  - Remote: ${repo.remote}`);
      if (repo.dirty) lines.push(`  - Local changes: ${repo.statusLines.join("; ")}`);
    }
  }
  if (sourceContext.content.latestBlog) {
    const blog = sourceContext.content.latestBlog;
    lines.push(`- Latest blog: ${blog.createdAt || "unknown date"} - ${blog.title || blog.slug}`);
    if (blog.category) lines.push(`  - Category: ${blog.category}`);
    if (blog.slug) lines.push(`  - Slug: ${blog.slug}`);
  }
  if (sourceContext.content.latestReviews?.length) {
    lines.push(`- Latest reviews: ${sourceContext.content.latestReviews.map((review) => `${review.name || review.id}${review.designation ? ` (${review.designation})` : ""}`).join("; ")}`);
  }
  return lines;
}

function formatConnectionPlan(discovery, company) {
  const plan = [];
  const wanted = new Set(stringArray(company.connectorsWanted).map((item) => item.toLowerCase()));
  const rows = connectorRows(discovery);
  const covered = new Set();
  for (const [name, ok, via, detail] of rows) {
    const key = name.toLowerCase().replace(/\s+/g, "-");
    covered.add(key);
    covered.add(name.toLowerCase());
    if (!wanted.size || wanted.has(key) || wanted.has(name.toLowerCase()) || ok) {
      plan.push(`- ${name}: ${ok ? `connected through ${via}` : `missing - ${detail || via}`}`);
    }
  }
  for (const requested of wanted) {
    if (covered.has(requested)) continue;
    plan.push(`- ${requested}: not connected yet - ${connectorSetupSteps(requested)}`);
  }
  if (company.websiteUrl) plan.push(`- Website: configured at ${company.websiteUrl}`);
  if (stringArray(company.localRepos).length) plan.push(`- Local repos: ${stringArray(company.localRepos).length} configured for code/content context`);
  if (stringArray(company.githubRepos).length) plan.push(`- GitHub repos: ${stringArray(company.githubRepos).join(", ")}`);
  return plan.length ? plan : ["- No source map configured yet. Continue onboarding and connect at least one data source."];
}

function connectorSetupSteps(name) {
  const value = String(name || "").toLowerCase();
  if (/postgres|mysql|mongo|supabase|database|db|sql|redis/.test(value)) {
    return "add an MCP/API connector with read-only credentials first, document tables/collections to inspect, then allow writes only after explicit confirmation";
  }
  if (/backend|logs|server|api|cloud|function|sentry|datadog|logtail|railway|render|vercel|netlify|aws|gcp/.test(value)) {
    return "connect logs/deploy provider through an MCP, CLI, or API token, then define which services, error levels, and deploy events matter";
  }
  if (/mail|email|gmail|outlook|support|zendesk|intercom|freshdesk|helpscout/.test(value)) {
    return "connect the inbox/support tool through OAuth or MCP, pick the account/queue, and define reply/urgent rules";
  }
  if (/slack|discord|teams/.test(value)) {
    return "connect the chat workspace, select channels to watch, and define which alerts or tasks deserve escalation";
  }
  if (/github|gitlab|repo|code/.test(value)) {
    return "connect GitHub/GitLab or add local repo paths, then define branches, deployment repos, and review/CI signals to watch";
  }
  if (/analytics|mixpanel|posthog|ga4|google analytics|amplitude|events/.test(value)) {
    return "connect analytics through API/MCP, choose key events and funnels, then define alert thresholds";
  }
  if (/stripe|razorpay|payment|billing|subscription/.test(value)) {
    return "connect payment provider API/MCP in read-only mode first, define payment/refund/subscription signals, and require confirmation for money changes";
  }
  if (/ads|meta|facebook|google ads|adwords|marketing/.test(value)) {
    return "connect ads API/MCP, choose ad accounts/campaigns, and require confirmation before spend, budget, or targeting changes";
  }
  if (/drive|docs|notion|confluence|wiki|obsidian|knowledge/.test(value)) {
    return "connect the docs/wiki source, select folders or spaces, and define which documents are operating memory";
  }
  if (/mcp|tool|api|internal/.test(value)) {
    return "install or register the MCP/API connector in OpenClaw, expose read tools first, then document any write tools that need approval";
  }
  return "add it as an OpenClaw MCP, API connector, CLI, or OAuth integration, then tell Ops Brain what to read, what to ignore, and what actions require approval";
}

function formatMailMatches(thresholdResult) {
  const gmail = thresholdResult.checks.find((check) => check.name === "Gmail important mail");
  if (!gmail || !gmail.items?.length) return ["- No important mail matched the current threshold."];
  return gmail.items.map((item) => `- ${item.date || "unknown date"} - ${item.from || "unknown sender"} - ${item.subject}`);
}

function sanitizeTable(value) {
  return String(value).replace(/\|/g, "\\|").replace(/\n/g, " ");
}

function resolveReportDir(config) {
  const { company } = activeCompany(config);
  const configured = expand(company.obsidianCompanyDir || "");
  if (configured) return configured;
  return DEFAULT_REPORTS_DIR;
}

function resolveVaultRoot(reportDir) {
  const parts = path.resolve(reportDir).split(path.sep);
  const wikiIndex = parts.lastIndexOf("wiki");
  if (wikiIndex > 0) return parts.slice(0, wikiIndex).join(path.sep) || path.sep;
  if (path.resolve(reportDir).startsWith(path.resolve(DEFAULT_WORK_VAULT_DIR))) return DEFAULT_WORK_VAULT_DIR;
  return "";
}

function ensureWorkVault(reportDir, config) {
  const vaultRoot = resolveVaultRoot(reportDir);
  if (!vaultRoot) return;
  const { company } = activeCompany(config);
  const dirs = [
    "raw",
    "raw/sources",
    "raw/assets",
    "wiki",
    "wiki/sources",
    "wiki/concepts",
    "wiki/entities",
    "wiki/projects",
    "wiki/questions",
    "wiki/reports",
    "wiki/syntheses"
  ];
  for (const dir of dirs) ensureDir(path.join(vaultRoot, dir));

  const indexPath = path.join(vaultRoot, "wiki", "index.md");
  if (!fs.existsSync(indexPath)) {
    fs.writeFileSync(indexPath, [
      "# Work Brain Index",
      "",
      "This is the dedicated Obsidian work vault for OpenClaw Ops Brain.",
      "",
      "## Companies",
      "",
      `- [[projects/${company.slug}-work-agent|${company.name} Ops Brain]]`,
      "",
      "## System Pages",
      "",
      "- [[log|Work Brain Log]]",
      ""
    ].join("\n"));
  }

  const logPath = path.join(vaultRoot, "wiki", "log.md");
  if (!fs.existsSync(logPath)) {
    fs.writeFileSync(logPath, [
      "# Work Brain Log",
      "",
      `- ${nowIso()} - Work vault initialized for ${company.name}.`,
      ""
    ].join("\n"));
  }
}

function writeReport(config, report) {
  const reportDir = resolveReportDir(config);
  ensureWorkVault(reportDir, config);
  ensureDir(reportDir);
  const date = new Date().toISOString().slice(0, 10);
  const file = path.join(reportDir, `${date}-work-agent-report.md`);
  fs.writeFileSync(file, report.markdown);
  appendJsonl(DEFAULT_LOG_PATH, { event: "report_written", file, summary: report.summary });
  return file;
}

function sendTelegram(config, text) {
  if (!config.notifyTarget) {
    return { ok: false, reason: "notifyTarget not configured" };
  }
  if (!commandExists("openclaw")) {
    return { ok: false, reason: "openclaw command not found" };
  }
  const target = String(config.notifyTarget);
  const [channelMaybe, targetMaybe] = target.includes(":") ? target.split(/:(.+)/) : ["telegram", target];
  const channel = channelMaybe || "telegram";
  const to = targetMaybe || target;
  const result = run("openclaw", ["message", "send", "--channel", channel, "--target", to, "--message", text], { timeout: 60000 });
  appendJsonl(DEFAULT_LOG_PATH, { event: "telegram_send", ok: result.ok, target: config.notifyTarget, stderr: result.stderr });
  return result.ok ? { ok: true } : { ok: false, reason: result.stderr || result.stdout };
}

function buildTelegramSummary(report, file) {
  const missing = report.summary.missingConnectors.length ? report.summary.missingConnectors.join(", ") : "none";
  const actions = report.summary.actionCandidates.slice(0, 3).map((item) => `- ${item}`).join("\n") || "- No connector blockers found.";
  return [
    `Ops Brain report for ${report.summary.company}`,
    `Mode: ${report.summary.permissionMode}`,
    `Missing connectors: ${missing}`,
    `Report: ${file}`,
    "",
    "Suggested actions:",
    actions
  ].join("\n");
}

function getOnboardingState(company) {
  const onboarding = company.onboarding || {};
  if (onboarding.completed) {
    const missingStep = firstMissingOnboardingStepId(company);
    if (missingStep) {
      return {
        ...onboarding,
        completed: false,
        currentStep: missingStep,
        answered: onboarding.answered || [],
        refinement: true
      };
    }
    return { ...onboarding, completed: true };
  }
  const hasExplicitProgress = Boolean(onboarding.currentStep || (onboarding.answered || []).length);
  if (!hasExplicitProgress && hasEnoughCompanyContext(company)) {
    return {
      ...onboarding,
      completed: true,
      currentStep: "",
      answered: onboarding.answered || [],
      inferred: true
    };
  }
  return {
    completed: false,
    currentStep: onboarding.currentStep || "startupName",
    answered: onboarding.answered || [],
    completedAt: onboarding.completedAt || ""
  };
}

function firstMissingOnboardingStepId(company) {
  const answered = new Set(company.onboarding?.answered || []);
  const missing = ONBOARDING_STEPS.find((step) => !answered.has(step.id) && !stepIsSatisfied(company, step.id));
  return missing?.id || "";
}

function stepIsSatisfied(company, stepId) {
  if (stepId === "startupName") return Boolean(company.name && company.name !== "My Startup");
  if (stepId === "businessSummary") return Boolean(company.businessSummary);
  if (stepId === "customerSegments") return stringArray(company.customerSegments).length > 0;
  if (stepId === "productSurfaces") return stringArray(company.productSurfaces).length > 0;
  if (stepId === "keyWorkflows") return stringArray(company.keyWorkflows).length > 0;
  if (stepId === "goals") return stringArray(company.goals).length > 0;
  if (stepId === "connectors") return stringArray(company.connectorsWanted).length > 0;
  if (stepId === "websiteUrl") return Boolean(company.websiteUrl);
  if (stepId === "repos") return stringArray(company.localRepos).length > 0 || stringArray(company.githubRepos).length > 0;
  if (stepId === "firebaseProject") return Boolean(company.firebaseProject);
  if (stepId === "gmailAccount") return Boolean(company.gmailAccount);
  if (stepId === "importantSignals") return stringArray(company.metricsToWatch).length > 0;
  if (stepId === "growthChannels") return stringArray(company.growthChannels).length > 0;
  if (stepId === "risks") return stringArray(company.risks).length > 0;
  if (stepId === "decisionRules") return stringArray(company.decisionRules).length > 0;
  if (stepId === "allowedActions") return Boolean(company.allowedActions);
  return false;
}

function hasEnoughCompanyContext(company) {
  return Boolean(
    company.name
    && company.name !== "My Startup"
    && (company.goals || []).length
    && (company.metricsToWatch || []).length
    && (company.firebaseProject || company.gmailAccount || company.obsidianCompanyDir)
  );
}

function currentOnboardingStep(onboarding) {
  return ONBOARDING_STEPS.find((step) => step.id === onboarding.currentStep) || ONBOARDING_STEPS[0];
}

function nextOnboardingStepId(company, currentStepId) {
  const index = ONBOARDING_STEPS.findIndex((step) => step.id === currentStepId);
  const answered = new Set([...(company.onboarding?.answered || []), currentStepId]);
  const remaining = ONBOARDING_STEPS.slice(index + 1);
  const next = remaining.find((step) => !answered.has(step.id) && !stepIsSatisfied(company, step.id));
  return next?.id || "";
}

function formatWorkHome(config, discovery) {
  const { key, company } = activeCompany(config);
  const onboarding = getOnboardingState(company);
  if (!onboarding.completed) {
    const step = currentOnboardingStep(onboarding);
    return [
      onboarding.refinement
        ? "Work mode is improving its company map. I found one new setup detail I still need, and I will not ask it again after you answer."
        : "Work mode is starting. I need to understand this company once, then I will not ask the same setup questions again.",
      "",
      `Question ${ONBOARDING_STEPS.findIndex((item) => item.id === step.id) + 1} of ${ONBOARDING_STEPS.length}:`,
      step.question
    ].join("\n");
  }

  const sourceContext = collectSourceContext(company);
  const rows = connectorRows(discovery);
  const connected = rows.filter(([, ok]) => ok).map(([name]) => name);
  const missing = rows.filter(([, ok]) => !ok).map(([name]) => name);
  const lastReport = latestReportPath(config);
  return [
    `Work mode is on for ${company.name}.`,
    "",
    "What I understand:",
    `- Company: ${company.name}`,
    ...(company.businessSummary ? [`- Business: ${company.businessSummary}`] : []),
    `- Customers/users: ${(company.customerSegments || []).join("; ") || "not set"}`,
    `- Product surfaces: ${(company.productSurfaces || []).join("; ") || "not set"}`,
    `- Critical workflows: ${(company.keyWorkflows || []).join("; ") || "not set"}`,
    `- Goals: ${(company.goals || []).join("; ") || "not set"}`,
    `- Growth channels: ${(company.growthChannels || []).join("; ") || "not set"}`,
    `- Risks to watch: ${(company.risks || []).join("; ") || "not set"}`,
    `- I should watch: ${(company.metricsToWatch || []).join("; ") || "not set"}`,
    `- Connected sources: ${connected.join(", ") || "none yet"}`,
    `- Missing or optional sources: ${missing.join(", ") || "none"}`,
    `- Website: ${company.websiteUrl || "not set"}`,
    ...formatRepoHomeLines(sourceContext.repos),
    ...formatContentHomeLines(sourceContext.content),
    `- Permission mode: ${config.permissionMode === "full" ? "full access, but sensitive actions still require confirmation" : "ask before execution"}`,
    `- Work vault: ${resolveVaultRoot(expand(company.obsidianCompanyDir || defaultObsidianCompanyDir(company.slug || key))) || DEFAULT_WORK_VAULT_DIR}`,
    lastReport ? `- Latest report: ${lastReport}` : "- Latest report: not created yet",
    "",
    "Live checks I should run through OpenClaw brain now:",
    "- First build the company picture from connected sources, then answer. Do not guess when a tool can verify it.",
    "- Firebase: online users from RTDB presence, users today, property/listing activity today, function errors, and product behavior signals.",
    "- Gmail: important feedback, leads, complaints, payment issues, and support messages.",
    "- Website/content: latest blogs/reviews, last push, SEO/content opportunities, and performance improvement ideas.",
    "",
    "Tell me what you want in plain English. I can inspect the connected sources, summarize what changed, suggest fixes, or ask before taking action."
  ].join("\n");
}

function formatRepoHomeLines(repos) {
  if (!repos.length) return ["- Codebases: not set"];
  return [
    `- Codebases: ${repos.map((repo) => repo.name).join(", ")}`,
    ...repos.slice(0, 3).map((repo) => `  - ${repo.name}: ${repo.latestCommit || "no commit found"}${repo.dirty ? " with local changes" : ""}`)
  ];
}

function formatContentHomeLines(content) {
  const lines = [];
  if (content.latestBlog) {
    lines.push(`- Latest website blog: ${content.latestBlog.createdAt || "unknown date"} - ${content.latestBlog.title || content.latestBlog.slug}`);
  }
  if (content.latestReviews?.length) {
    lines.push(`- Latest review seeds: ${content.latestReviews.map((review) => `${review.name || review.id}${review.designation ? ` (${review.designation})` : ""}`).join("; ")}`);
  }
  return lines.length ? lines : ["- Website content: not read yet"];
}

function latestReportPath(config) {
  const reportDir = resolveReportDir(config);
  if (!fs.existsSync(reportDir)) return "";
  const files = fs.readdirSync(reportDir)
    .filter((name) => /work-agent-report\.md$/.test(name))
    .sort()
    .reverse();
  return files[0] ? path.join(reportDir, files[0]) : "";
}

function collectSourceContext(company) {
  const localRepos = stringArray(company.localRepos).map(expand);
  const repos = localRepos.map(readRepoContext).filter(Boolean);
  const websiteRepo = repos.find((repo) => fs.existsSync(path.join(repo.path, "src", "data", "blogs.ts")))
    || repos.find((repo) => /website|web/i.test(repo.name));
  const content = websiteRepo ? readWebsiteContentContext(websiteRepo.path) : {};
  return { repos, content };
}

function readRepoContext(repoPath) {
  if (!repoPath || !fs.existsSync(repoPath)) return null;
  const name = path.basename(repoPath);
  const inside = run("git", ["-C", repoPath, "rev-parse", "--is-inside-work-tree"], { timeout: 10000 });
  if (!inside.ok || inside.stdout.trim() !== "true") return { name, path: repoPath, ok: false, latestCommit: "", dirty: false };
  const latestCommit = run("git", ["-C", repoPath, "log", "-1", "--pretty=%h %s"], { timeout: 10000 }).stdout || "";
  const branch = run("git", ["-C", repoPath, "branch", "--show-current"], { timeout: 10000 }).stdout || "";
  const remote = run("git", ["-C", repoPath, "remote", "get-url", "origin"], { timeout: 10000 }).stdout || "";
  const status = run("git", ["-C", repoPath, "status", "--short"], { timeout: 10000 }).stdout || "";
  return {
    name,
    path: repoPath,
    ok: true,
    branch,
    remote,
    latestCommit,
    dirty: Boolean(status.trim()),
    statusLines: status.split(/\r?\n/).filter(Boolean).slice(0, 8)
  };
}

function readWebsiteContentContext(repoPath) {
  const dataDir = path.join(repoPath, "src", "data");
  const blogsFile = path.join(dataDir, "blogs.ts");
  const reviewsFile = path.join(dataDir, "reviews.ts");
  return {
    latestBlog: fs.existsSync(blogsFile) ? parseLatestBlog(blogsFile) : null,
    latestReviews: fs.existsSync(reviewsFile) ? parseLatestReviews(reviewsFile) : []
  };
}

function parseLatestBlog(file) {
  const text = fs.readFileSync(file, "utf8");
  const firstObject = text.match(/export const blogPosts[\s\S]*?\{\s*slug:\s*"([^"]+)"([\s\S]*?)\n\s*\},/);
  if (!firstObject) return null;
  const body = firstObject[2] || "";
  return {
    slug: firstObject[1],
    title: matchStringProperty(body, "title") || "",
    description: matchStringProperty(body, "description") || "",
    createdAt: matchStringProperty(body, "createdAt") || "",
    category: matchStringProperty(body, "category") || ""
  };
}

function parseLatestReviews(file) {
  const text = fs.readFileSync(file, "utf8");
  const block = text.match(/const REVIEW_SEEDS[\s\S]*?=\s*\[([\s\S]*?)\n\s*\];/);
  if (!block) return [];
  const matches = [...block[1].matchAll(/\{\s*id:\s*"([^"]+)"([\s\S]*?)\n\s*\},/g)].slice(0, 2);
  return matches.map((match) => ({
    id: match[1],
    name: matchStringProperty(match[2], "name") || "",
    designation: matchStringProperty(match[2], "designation") || "",
    quote: matchStringProperty(match[2], "quote") || ""
  }));
}

function matchStringProperty(text, property) {
  const direct = text.match(new RegExp(`${property}:\\s*"([^"]+)"`));
  if (direct) return direct[1];
  const multiline = text.match(new RegExp(`${property}:\\s*\\n\\s*"([^"]+)"`));
  return multiline ? multiline[1] : "";
}

function homeCommand(args) {
  const { config } = loadConfig(args);
  const discovery = discoverConnectors(config);
  console.log(formatWorkHome(config, discovery));
}

function answerCommand(args) {
  const answer = args._.slice(1).join(" ").trim();
  if (!answer) fail("Missing onboarding answer.");
  const { config, configPath } = loadConfig(args);
  const key = config.activeCompany || "default";
  const company = mergeConfig(DEFAULT_CONFIG.companies.default, config.companies?.[key] || {});
  const onboarding = getOnboardingState(company);
  if (onboarding.completed) {
    console.log(formatWorkHome(config, discoverConnectors(config)));
    return;
  }

  const step = currentOnboardingStep(onboarding);
  const updated = applyOnboardingAnswer(config, key, company, step.id, answer);
  const updatedKey = updated.activeCompany || key;
  const updatedCompany = updated.companies[updatedKey];
  const nextStepId = nextOnboardingStepId(updatedCompany, step.id);
  updated.companies[updatedKey].onboarding = {
    completed: !nextStepId,
    currentStep: nextStepId,
    answered: [...(updatedCompany.onboarding?.answered || company.onboarding?.answered || []), step.id],
    completedAt: nextStepId ? "" : nowIso()
  };
  writeJson(configPath, updated);

  if (nextStepId) {
    const next = ONBOARDING_STEPS.find((item) => item.id === nextStepId);
    console.log([
      "Got it. I saved that.",
      "",
      `Next question ${ONBOARDING_STEPS.findIndex((item) => item.id === next.id) + 1} of ${ONBOARDING_STEPS.length}:`,
      next.question
    ].join("\n"));
    return;
  }

  const discovery = discoverConnectors(updated);
  const report = buildReport(updated, discovery, { dryRun: true, scheduled: false });
  const file = writeReport(updated, report);
  console.log([
    "Onboarding is complete. I will not ask those setup questions again unless you add something new.",
    "",
    formatWorkHome(updated, discovery),
    "",
    `I also wrote the first work-brain report here: ${file}`
  ].join("\n"));
}

function applyOnboardingAnswer(config, key, company, stepId, answer) {
  const updated = structuredClone(config);
  const target = {
    ...company,
    onboarding: { ...(company.onboarding || {}) }
  };
  if (stepId === "startupName") {
    target.name = answer;
    target.slug = slugify(answer);
    if (key === "default") {
      delete updated.companies.default;
      updated.activeCompany = target.slug;
      updated.companies[target.slug] = target;
      if (!target.obsidianCompanyDir) target.obsidianCompanyDir = defaultObsidianCompanyDir(target.slug);
      return updated;
    }
  }
  if (stepId === "businessSummary") target.businessSummary = answer;
  if (stepId === "customerSegments") target.customerSegments = splitPlainList(answer);
  if (stepId === "productSurfaces") target.productSurfaces = splitPlainList(answer);
  if (stepId === "keyWorkflows") target.keyWorkflows = splitPlainList(answer);
  if (stepId === "goals") target.goals = splitPlainList(answer);
  if (stepId === "connectors") target.connectorsWanted = splitPlainList(answer);
  if (stepId === "websiteUrl") target.websiteUrl = noneToEmpty(answer);
  if (stepId === "repos") {
    const repos = splitPlainList(answer).filter(Boolean);
    target.localRepos = repos.filter((item) => item.startsWith("/") || item.startsWith("~"));
    target.githubRepos = repos.filter((item) => !item.startsWith("/") && !item.startsWith("~") && item !== "none");
  }
  if (stepId === "firebaseProject") target.firebaseProject = noneToEmpty(answer);
  if (stepId === "gmailAccount") target.gmailAccount = noneToEmpty(answer);
  if (stepId === "importantSignals") {
    target.metricsToWatch = splitPlainList(answer);
    target.thresholds = target.thresholds || structuredClone(DEFAULT_CONFIG.companies.default.thresholds);
    target.thresholds.gmailImportant = {
      ...DEFAULT_CONFIG.companies.default.thresholds.gmailImportant,
      ...(target.thresholds.gmailImportant || {}),
      queryTerms: splitPlainList(answer).slice(0, 20)
    };
  }
  if (stepId === "growthChannels") target.growthChannels = splitPlainList(answer);
  if (stepId === "risks") target.risks = splitPlainList(answer);
  if (stepId === "decisionRules") target.decisionRules = splitPlainList(answer);
  if (stepId === "allowedActions") target.allowedActions = answer;
  if (!target.obsidianCompanyDir) target.obsidianCompanyDir = defaultObsidianCompanyDir(target.slug || key);
  updated.companies[updated.activeCompany || key] = target;
  return updated;
}

function splitPlainList(value) {
  const text = String(value || "").trim();
  if (!text) return [];
  return text
    .split(/\n|,|;|\band\b/i)
    .map((item) => item.replace(/^[-*0-9. )]+/, "").trim())
    .filter(Boolean);
}

function noneToEmpty(value) {
  return /^(none|no|not now|skip|n\/a)$/i.test(String(value).trim()) ? "" : String(value).trim();
}

async function initCommand(args) {
  const configPath = expand(args.config || DEFAULT_CONFIG_PATH);
  let config = structuredClone(DEFAULT_CONFIG);
  if (args.from) {
    const profile = readJson(expand(args.from), null);
    if (!profile) fail(`Could not read profile JSON: ${args.from}`);
    config = mergeConfig(config, profile);
  } else if (fs.existsSync(configPath) && !args.force) {
    config = mergeConfig(config, readJson(configPath, {}));
  }

  if (!args.yes && process.stdin.isTTY) {
    const rl = readline.createInterface({ input, output });
    const current = activeCompany(config).company;
    const startupName = await ask(rl, "Startup/company name", current.name);
    const slug = slugify(startupName);
    const businessSummary = await ask(rl, "What does this company do and who is it for?", current.businessSummary || "");
    const customerSegments = await ask(rl, "Customers/users/buyers/operators, comma-separated", (current.customerSegments || []).join(", "));
    const productSurfaces = await ask(rl, "Product surfaces to watch, comma-separated", (current.productSurfaces || []).join(", "));
    const keyWorkflows = await ask(rl, "Critical workflows, comma-separated", (current.keyWorkflows || []).join(", "));
    const notifyTarget = await ask(rl, "Notification target, for example telegram:123456789", config.notifyTarget || process.env.WORK_AGENT_NOTIFY_TARGET || "");
    const permissionMode = await ask(rl, "Permission mode: ask or full", config.permissionMode || "ask");
    const websiteUrl = await ask(rl, "Website or product URL", current.websiteUrl || "");
    const localRepos = await ask(rl, "Local repo paths, comma-separated", (current.localRepos || []).join(", "));
    const githubRepos = await ask(rl, "GitHub repos, comma-separated", (current.githubRepos || []).join(", "));
    const firebaseProject = await ask(rl, "Firebase project ID", current.firebaseProject || "");
    const gmailAccount = await ask(rl, "Gmail account", current.gmailAccount || "");
    const driveFolders = await ask(rl, "Drive folder IDs or URLs, comma-separated", (current.driveFolders || []).join(", "));
    const obsidianCompanyDir = await ask(rl, "Obsidian company folder path", current.obsidianCompanyDir || defaultObsidianCompanyDir(slug));
    const metricsToWatch = await ask(rl, "Metrics to watch, comma-separated", (current.metricsToWatch || []).join(", "));
    const goals = await ask(rl, "Business goals, comma-separated", (current.goals || []).join(", "));
    const growthChannels = await ask(rl, "Growth channels, comma-separated", (current.growthChannels || []).join(", "));
    const risks = await ask(rl, "Risks and care points, comma-separated", (current.risks || []).join(", "));
    const decisionRules = await ask(rl, "Decision rules or founder preferences, comma-separated", (current.decisionRules || []).join(", "));
    const importantTerms = await ask(rl, "Important Gmail terms, comma-separated", (current.thresholds?.gmailImportant?.queryTerms || DEFAULT_CONFIG.companies.default.thresholds.gmailImportant.queryTerms).join(", "));
    const gmailLookback = await ask(rl, "Important Gmail lookback, for example 1d or 7d", current.thresholds?.gmailImportant?.lookback || "1d");
    const gmailNotifyOnCount = await ask(rl, "Notify/action threshold for important Gmail count", String(current.thresholds?.gmailImportant?.notifyOnCount ?? 1));
    rl.close();

    config.activeCompany = slug;
    config.permissionMode = normalizeMode(permissionMode);
    config.notifyTarget = notifyTarget.trim();
    config.companies = {
      [slug]: {
        ...current,
        name: startupName,
        slug,
        businessSummary: businessSummary.trim(),
        customerSegments: splitList(customerSegments),
        productSurfaces: splitList(productSurfaces),
        keyWorkflows: splitList(keyWorkflows),
        websiteUrl: websiteUrl.trim(),
        localRepos: splitList(localRepos),
        githubRepos: splitList(githubRepos),
        firebaseProject: firebaseProject.trim(),
        gmailAccount: gmailAccount.trim(),
        driveFolders: splitList(driveFolders),
        obsidianCompanyDir: obsidianCompanyDir.trim(),
        metricsToWatch: splitList(metricsToWatch),
        goals: splitList(goals),
        growthChannels: splitList(growthChannels),
        risks: splitList(risks),
        decisionRules: splitList(decisionRules),
        thresholds: {
          ...(current.thresholds || DEFAULT_CONFIG.companies.default.thresholds),
          gmailImportant: {
            ...(current.thresholds?.gmailImportant || DEFAULT_CONFIG.companies.default.thresholds.gmailImportant),
            queryTerms: splitList(importantTerms),
            lookback: gmailLookback.trim() || "1d",
            notifyOnCount: Number.parseInt(gmailNotifyOnCount, 10) || 1
          }
        }
      }
    };
  }

  writeJson(configPath, config);
  ensureDir(path.dirname(DEFAULT_LOG_PATH));
  appendJsonl(DEFAULT_LOG_PATH, { event: "init", configPath, activeCompany: config.activeCompany });
  console.log(`Wrote Ops Brain config: ${configPath}`);
}

async function ask(rl, prompt, fallback = "") {
  const suffix = fallback ? ` [${fallback}]` : "";
  const answer = await rl.question(`${prompt}${suffix}: `);
  return answer.trim() || fallback;
}

function defaultObsidianCompanyDir(slug) {
  return path.join(DEFAULT_WORK_VAULT_DIR, "wiki", "projects", `${slug}-work-agent`);
}

function splitList(value) {
  return String(value || "")
    .split(",")
    .map((item) => item.trim())
    .filter(Boolean);
}

function slugify(value) {
  return String(value || "company")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "")
    .slice(0, 60) || "company";
}

function normalizeMode(value) {
  return /^full/i.test(String(value)) ? "full" : "ask";
}

function fail(message, code = 1) {
  console.error(message);
  process.exit(code);
}

function modeCommand(args) {
  const nextMode = normalizeMode(args._[1] || "");
  if (!["ask", "full"].includes(nextMode)) fail("Usage: openclaw-work-agent mode ask|full");
  const { config, configPath } = loadConfig(args);
  config.permissionMode = nextMode;
  writeJson(configPath, config);
  appendJsonl(DEFAULT_LOG_PATH, { event: "mode_changed", mode: nextMode });
  console.log(`Permission mode set to ${nextMode === "full" ? "full-access" : "ask-then-execute"}`);
}

function statusCommand(args) {
  const { config } = loadConfig(args);
  const discovery = discoverConnectors(config);
  printStatus(discovery, Boolean(args.json));
}

function runCommand(args) {
  const { config } = loadConfig(args);
  const discovery = discoverConnectors(config);
  const thresholdResult = runThresholdChecks(config, discovery, {
    dryRun: Boolean(args["dry-run"]),
    scheduled: Boolean(args.scheduled)
  });
  const report = buildReport(config, discovery, {
    dryRun: Boolean(args["dry-run"]),
    scheduled: Boolean(args.scheduled),
    thresholdResult
  });
  const file = writeReport(config, report);
  console.log(`Wrote report: ${file}`);

  const shouldNotify = Boolean(args.notify)
    || (!args["dry-run"] && !args.scheduled && Boolean(config.notifyTarget))
    || (!args["dry-run"] && args.scheduled && thresholdResult.actionRequired && Boolean(config.notifyTarget));

  if (shouldNotify) {
    const sent = sendTelegram(config, buildTelegramSummary(report, file));
    console.log(sent.ok ? "Sent notification." : `Notification skipped: ${sent.reason}`);
  } else if (args["dry-run"]) {
    console.log("Dry run: no external notification sent.");
  } else if (args.scheduled) {
    console.log("Scheduled run: quiet mode, no notification sent.");
  }
}

function thresholdsCommand(args) {
  const sub = args._[1] || "show";
  const { config, configPath } = loadConfig(args);
  const { company } = activeCompany(config);
  if (sub === "show") {
    console.log(JSON.stringify(company.thresholds || {}, null, 2));
    return;
  }
  if (sub === "set-gmail") {
    const terms = args.terms ? splitList(args.terms) : null;
    const lookback = args.lookback ? String(args.lookback) : null;
    const notifyOnCount = args.count ? Number.parseInt(String(args.count), 10) : null;
    const key = config.activeCompany || "default";
    config.companies[key].thresholds = config.companies[key].thresholds || structuredClone(DEFAULT_CONFIG.companies.default.thresholds);
    config.companies[key].thresholds.gmailImportant = {
      ...DEFAULT_CONFIG.companies.default.thresholds.gmailImportant,
      ...(config.companies[key].thresholds.gmailImportant || {}),
      ...(terms ? { queryTerms: terms } : {}),
      ...(lookback ? { lookback } : {}),
      ...(notifyOnCount ? { notifyOnCount } : {})
    };
    writeJson(configPath, config);
    console.log("Updated Gmail important-mail threshold.");
    console.log(JSON.stringify(config.companies[key].thresholds.gmailImportant, null, 2));
    return;
  }
  fail("Usage: openclaw-work-agent thresholds show | thresholds set-gmail --terms \"feedback,bug\" --lookback 1d --count 1");
}

function askCommand(args) {
  const question = args._.slice(1).join(" ").trim();
  if (!question) fail("Usage: openclaw-work-agent ask <question>");
  const { config } = loadConfig(args);
  const discovery = discoverConnectors(config);
  const { company } = activeCompany(config);
  const reportDir = expand(company.obsidianCompanyDir || defaultObsidianCompanyDir(company.slug || "company"));
  const vaultRoot = resolveVaultRoot(reportDir);
  const obsidian = path.join(DEFAULT_TOOLS_DIR, "openclaw-obsidian");
  const source = fs.existsSync(obsidian) ? obsidian : commandExists("openclaw-obsidian") ? "openclaw-obsidian" : "";

  if (!source) {
    console.log("Obsidian bridge is not installed. Use the connector status below to continue manually.");
    printStatus(discovery);
    return;
  }

  const result = run(source, ["search", question], {
    timeout: 60000,
    env: vaultRoot ? { OPENCLAW_OBSIDIAN_VAULT: vaultRoot } : {}
  });
  if (result.ok && result.stdout) {
    console.log(result.stdout);
  } else {
    console.log("No direct Obsidian answer found. Use `/work run` to refresh the company report, then ask again.");
    if (result.stderr) console.log(result.stderr);
  }
}

function cronCommand(args) {
  const sub = args._[1] || "";
  if (sub !== "install") fail("Usage: openclaw-work-agent cron install");
  const { config } = loadConfig(args);
  if (!commandExists("openclaw")) fail("openclaw command not found");
  const target = parseNotifyTarget(config.notifyTarget);
  if (!target) fail("notifyTarget must be configured, for example telegram:123456789");

  const existing = run("openclaw", ["cron", "list"], { timeout: 30000 }).stdout || "";
  const jobs = [
    {
      name: "Ops Brain Light Monitor",
      every: "30m",
      message: buildBrainLoopMessage("light")
    },
    {
      name: "Ops Brain Daily Deep Report",
      cron: "15 9 * * *",
      message: buildBrainLoopMessage("deep")
    }
  ];

  for (const job of jobs) {
    if (existing.includes(job.name)) {
      console.log(`Cron already exists: ${job.name}`);
      continue;
    }
    const addArgs = [
      "cron", "add",
      "--name", job.name,
      "--message", job.message,
      "--session", "isolated",
      "--channel", target.channel,
      "--to", target.target,
      "--no-deliver",
      "--best-effort-deliver",
      "--timeout-seconds", "600"
    ];
    if (job.every) addArgs.push("--every", job.every);
    if (job.cron) addArgs.push("--cron", job.cron, "--tz", "Asia/Kolkata");
    const result = run("openclaw", addArgs, { timeout: 60000 });
    console.log(result.ok ? `Installed cron: ${job.name}` : `Failed cron ${job.name}: ${result.stderr || result.stdout}`);
  }
}

function buildBrainLoopMessage(kind) {
  if (kind === "light") {
    return [
      "Run the OpenClaw Ops Brain light monitor.",
      "Use the work-agent skill, the agent profile at `~/.openclaw/workspace/agents/work-agent.md`, and your own reasoning, not only deterministic keyword matching.",
      "First run `~/.openclaw/tools/openclaw-work-agent run --scheduled light` to collect connector status, threshold candidates, and write the work-vault report.",
      "Then inspect the report and, if useful, use any connected tool or MCP to decide whether anything is genuinely important.",
      "If the company needs another system connected, write the shortest setup steps for that database, backend, mail, chat, repo, analytics, payment, ads, docs, support, API, or MCP source.",
      "Think through the full company map: customers, product surfaces, workflows, growth channels, risks, and decision rules.",
      "For Firebase rental-marketplace context, check online users, users today, properties/listings updated today, and function/backend errors when tools are available.",
      "For website context, consider latest blog/review content, latest repo push, conversion opportunities, performance improvements, and SEO suggestions.",
      "Update the work vault with any meaningful finding.",
      "Stay silent unless a real action is needed. Do not send email, mutate Firebase, deploy, delete, or change ad/payment settings without explicit confirmation."
    ].join(" ");
  }
  return [
    "Run the OpenClaw Ops Brain daily deep report.",
    "Use the work-agent skill, the agent profile at `~/.openclaw/workspace/agents/work-agent.md`, and your own reasoning to synthesize the company's current operating context.",
    "First run `~/.openclaw/tools/openclaw-work-agent run --scheduled deep` to collect connector status, threshold candidates, and write the work-vault report.",
    "Then read the latest work-vault report and relevant work memory, inspect connected sources if needed, and update the work brain with decisions, repeated issues, suggested thresholds, connector setup steps, and automation candidates.",
    "Include full company-map gaps, live business snapshot, repo/content context, product improvement ideas, SEO/content suggestions, and backend/Firebase issues that should be fixed or assigned.",
    "Only notify the user if there is a decision or action worth taking. Do not send external replies or mutate production systems without explicit confirmation."
  ].join(" ");
}

function parseNotifyTarget(value) {
  if (!value) return null;
  const target = String(value);
  if (target.includes(":")) {
    const [channel, rest] = target.split(/:(.+)/);
    return { channel: channel || "telegram", target: rest };
  }
  return { channel: "telegram", target };
}

function printHelp() {
  console.log(`OpenClaw Ops Brain

Usage:
  openclaw-work-agent
  openclaw-work-agent answer "plain English onboarding answer"
  openclaw-work-agent init [--from examples/uphomes.example.json] [--yes]
  openclaw-work-agent status [--json]
  openclaw-work-agent run [--dry-run] [--scheduled] [--notify]
  openclaw-work-agent ask <question>
  openclaw-work-agent mode ask|full
  openclaw-work-agent thresholds show
  openclaw-work-agent thresholds set-gmail --terms "feedback,bug,refund" --lookback 1d --count 1
  openclaw-work-agent cron install

Runtime:
  Config: ${DEFAULT_CONFIG_PATH}
  Reports: configured Obsidian company folder, else ${DEFAULT_REPORTS_DIR}
`);
}

async function main() {
  const args = parseArgs(process.argv.slice(2));
  const command = args._[0] || "home";
  if (command === "help" || command === "--help" || command === "-h") return printHelp();
  if (command === "home") return homeCommand(args);
  if (command === "answer") return answerCommand(args);
  if (command === "init") return initCommand(args);
  if (command === "status") return statusCommand(args);
  if (command === "run") return runCommand(args);
  if (command === "ask") return askCommand(args);
  if (command === "mode") return modeCommand(args);
  if (command === "thresholds") return thresholdsCommand(args);
  if (command === "cron") return cronCommand(args);
  fail(`Unknown command: ${command}`);
}

main().catch((error) => fail(error.stack || error.message || String(error)));
