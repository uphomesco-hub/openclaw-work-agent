# Optional overrides for local installs. Do not put real secrets in this file.

OPENCLAW_WORK_AGENT_DIR="$HOME/.openclaw/work-agent"
OPENCLAW_TOOLS_DIR="$HOME/.openclaw/tools"
OPENCLAW_WORKSPACE_DIR="$HOME/.openclaw/workspace"
OPENCLAW_WORK_VAULT_DIR="$HOME/Documents/Obsidian-Work-Brain"

# Optional default notification target, for example telegram:123456789.
WORK_AGENT_NOTIFY_TARGET=""

# Optional Obsidian company folder. Defaults to a folder inside the work-only vault.
WORK_AGENT_OBSIDIAN_COMPANY_DIR=""
